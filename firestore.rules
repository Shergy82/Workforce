rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
      return getUserData().role;
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'owner');
    }
    
    function isManager() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'manager' || getUserRole() == 'owner');
    }
    
    function isSupervisor() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'manager' || getUserRole() == 'supervisor' || getUserRole() == 'owner');
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for each collection
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation during setup or by admins
      allow create: if isAuthenticated() && (isAdmin() || isOwner(userId));
      // Only admins can change roles, users can edit their profile info (not role)
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /sites/{siteId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /planners/{plannerId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated() && (isSupervisor() || resource.data.userId == request.auth.uid);
      allow write: if isManager();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (isSupervisor() || resource.data.assignedTo == request.auth.uid || resource.data.assignedTeamMember == true);
      allow create: if isSupervisor();
      // Operative can only update completion status, notes, or photo
      allow update: if isSupervisor() || (
        isAuthenticated() && 
        (resource.data.assignedTo == request.auth.uid) && 
        (request.resource.data.title == resource.data.title && request.resource.data.assignedTo == resource.data.assignedTo)
      );
      allow delete: if isManager();
    }

    match /timesheets/{timesheetId} {
      allow read: if isAuthenticated() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isManager());
      allow update: if isAuthenticated() && (
        isManager() || 
        (resource.data.userId == request.auth.uid && resource.data.approvedStatus != 'approved')
      );
      allow delete: if isManager();
    }

    match /forms/{formId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /formSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.members);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.members);
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated(); // Controlled further via query filters
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    match /holidayRequests/{requestId} {
      allow read: if isAuthenticated() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isManager() || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isManager() || (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
    }

    match /absences/{absenceId} {
      allow read: if isAuthenticated() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isManager();
      allow delete: if isManager();
    }

    match /trainingRecords/{recordId} {
      allow read: if isAuthenticated() && (isManager() || resource.data.userId == request.auth.uid);
      allow write: if isManager();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
